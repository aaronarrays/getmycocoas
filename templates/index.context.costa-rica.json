              "disabled": false,
              "blocks": {
                "text_8z6AFd": {
                  "type": "text",
                  "name": "t:names.text",
                  "disabled": false,
                  "settings": {
                    "text": "<p>Sí, nuestra rasuradora íntima masculina MyCOCOS® 4.0 es a prueba de agua y puede ser usada en la ducha o en la bañera sin preocupaciones.</p>",
                    "header-806d901164e4d405f94e202668be8733": null,
