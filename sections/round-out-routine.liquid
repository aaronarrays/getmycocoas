{% comment %}
  Round out your routine - Sección tipo MANSCAPED: título + grid/carrusel de productos con imagen, card overlay y CTA.
  Cada bloque: imagen de fondo, producto (opcional), subtítulo, headline, descripción, botón Add.
{% endcomment %}

{% liquid
  assign section_title = section.settings.title | default: 'Round out your routine.'
  assign title_highlight = section.settings.title_highlight
  assign bg_color = section.settings.background_color | default: '#1a1a1a'
  assign text_color = section.settings.text_color | default: '#ffffff'
  assign accent_color = section.settings.accent_color | default: '#ffba25'
  assign accent_text = section.settings.accent_text_color | default: '#011732'
%}

<div
  class="round-out-routine section section--{{ section.settings.section_width }}"
  style="
    background-color: {{ bg_color }};
    {% if section.settings.background_image %}
      background-image: url({{ section.settings.background_image | image_url: width: 2000 }});
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
    --ror-card-bg: {{ section.settings.content_background_color | default: '#1a1a1a' }};
    --ror-bg: {{ bg_color }};
    --ror-text: {{ text_color }};
    --ror-headline-color: {{ section.settings.headline_color | default: text_color }};
    --ror-description-color: {{ section.settings.description_color | default: text_color }};
    --ror-accent: {{ accent_color }};
    --ror-accent-text: {{ accent_text }};
    {% render 'spacing-style', settings: section.settings %}
  "
>
  <div class="round-out-routine__inner">
    <div class="round-out-routine__header">
      <h2 class="round-out-routine__title">
        {% if title_highlight != blank %}
          <span class="round-out-routine__title-highlight" style="background-color: {{ title_highlight }};">{{ section_title }}</span>
        {% else %}
          {{ section_title }}
        {% endif %}
      </h2>
    </div>

    <div class="round-out-routine__slider {% if section.blocks.size == 1 %}round-out-routine__slider--single{% endif %}" data-round-out-routine id="round-out-routine-{{ section.id }}">
      <div class="round-out-routine__track" data-ror-track>
      {% for block in section.blocks %}
        {% if block.type != 'item' %}
          {% continue %}
        {% endif %}
        {% liquid
          assign item_image = block.settings.image
          assign item_image_mobile = block.settings.image_mobile
          assign item_product = block.settings.product
          assign item_headline = block.settings.headline
          assign item_description = block.settings.description
          assign item_button_label = block.settings.button_label | default: 'Add'
          assign product_title = item_product.title | default: block.settings.product_title_override
          assign product_subtitle = block.settings.product_subtitle
          if product_title == blank and block.settings.product_title_override != blank
            assign product_title = block.settings.product_title_override
          elsif product_title == blank and item_product != blank
            assign product_title = item_product.title
          endif

          assign variant = item_product.selected_or_first_available_variant
          assign can_add = false
          if variant and variant.available
            assign can_add = true
          endif
          assign product_price = ''
if variant
  assign product_price = variant.price | money
endif
          assign image_fit = block.settings.image_fit | default: 'cover'
          assign image_position = block.settings.image_position | default: 'center'
          assign image_aspect = block.settings.image_aspect_ratio | default: '1'
          if image_aspect == 'auto'
            assign image_aspect = '1'
          endif
        %}
        <div class="round-out-routine__card" {{ block.shopify_attributes }}>
          {% comment %} Zona de la foto: solo la imagen + overlay con info del producto y Add {% endcomment %}
          <div class="round-out-routine__card-media" style="--ror-object-fit: {{ image_fit }}; --ror-object-position: {{ image_position }}; --ror-aspect-ratio: {{ image_aspect }};">
            {% if item_image != blank %}
              {% if item_image_mobile != blank %}
                <picture>
                  <source media="(max-width: 749px)" srcset="{{ item_image_mobile | image_url: width: 670 }}">
                  <img src="{{ item_image | image_url: width: 820 }}" alt="{{ item_image.alt | escape }}" class="round-out-routine__card-image" loading="lazy" width="820" height="{{ 820 | divided_by: item_image.aspect_ratio | round }}">
                </picture>
              {% else %}
                {% render 'image', image: item_image, class: 'round-out-routine__card-image' %}
              {% endif %}
            {% else %}
              <div class="round-out-routine__placeholder">
                {{ 'lifestyle-1' | placeholder_svg_tag: 'round-out-routine__placeholder-svg' }}
              </div>
            {% endif %}
            {% comment %} Desktop: barra sobre la imagen (esquina inferior derecha) con miniatura + nombre + subtítulo + Add {% endcomment %}
            <div class="round-out-routine__product-bar round-out-routine__product-bar--overlay">
              {% if item_product != blank and item_product.featured_image != blank %}
                <div class="round-out-routine__product-thumb">
                  {% render 'image', image: item_product.featured_image, height: 120, class: 'round-out-routine__product-thumb-img' %}
                </div>
              {% endif %}
              <div class="round-out-routine__product-info">
  {% if product_title != blank %}
    <span class="round-out-routine__product-name">{{ product_title }}</span>
  {% endif %}

  {% if product_price != blank %}
    <span class="round-out-routine__product-price">{{ product_price }}</span>
  {% endif %}

  {% if product_subtitle != blank %}
    <span class="round-out-routine__product-subtitle">{{ product_subtitle }}</span>
  {% endif %}
</div>
              {% if item_product != blank and variant != blank %}
                {% assign form_id_overlay = 'ror-form-overlay-' | append: section.id | append: '-' | append: block.id %}
                {% form 'product', item_product, id: form_id_overlay, data-type: 'add-to-cart-form' %}
                  <input type="hidden" name="id" value="{{ variant.id }}">
                  <input type="hidden" name="return_to" value="{{ request.path }}">
                  <button type="submit" class="round-out-routine__btn" {% unless can_add %}disabled{% endunless %}>{{ item_button_label }}</button>
                {% endform %}
              {% elsif item_product != blank %}
                <a href="{{ item_product.url }}" class="round-out-routine__btn">{{ item_button_label }}</a>
              {% elsif block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="round-out-routine__btn">{{ item_button_label }}</a>
              {% else %}
                <span class="round-out-routine__btn round-out-routine__btn--disabled">{{ item_button_label }}</span>
              {% endif %}
            </div>
          </div>

          {% comment %} Móvil: barra debajo de la foto, solo título + botón {% endcomment %}
          <div class="round-out-routine__product-bar round-out-routine__product-bar--below">
            <div class="round-out-routine__product-info">
  {% if product_title != blank %}
    <span class="round-out-routine__product-name">{{ product_title }}</span>
  {% endif %}

  {% if product_price != blank %}
    <span class="round-out-routine__product-price">{{ product_price }}</span>
  {% endif %}
</div>
            {% if item_product != blank and variant != blank %}
              {% assign form_id = 'ror-form-' | append: section.id | append: '-' | append: block.id %}
              {% form 'product', item_product, id: form_id, data-type: 'add-to-cart-form' %}
                <input type="hidden" name="id" value="{{ variant.id }}">
                <input type="hidden" name="return_to" value="{{ request.path }}">
                <button type="submit" class="round-out-routine__btn" {% unless can_add %}disabled{% endunless %}>{{ item_button_label }}</button>
              {% endform %}
            {% elsif item_product != blank %}
              <a href="{{ item_product.url }}" class="round-out-routine__btn">{{ item_button_label }}</a>
            {% elsif block.settings.button_link != blank %}
              <a href="{{ block.settings.button_link }}" class="round-out-routine__btn">{{ item_button_label }}</a>
            {% else %}
              <span class="round-out-routine__btn round-out-routine__btn--disabled">{{ item_button_label }}</span>
            {% endif %}
          </div>

          {% comment %} Debajo: headline y descripción {% endcomment %}
          <div class="round-out-routine__card-content">
            {% if item_headline != blank %}
              <h3 class="round-out-routine__headline">{{ item_headline }}</h3>
            {% endif %}
            {% if item_description != blank %}
              <p class="round-out-routine__description">{{ item_description }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
      </div>
    </div>

    {% if section.blocks.size > 1 %}
      <nav class="round-out-routine__nav" aria-label="Navegación del carrusel">
        <button type="button" class="round-out-routine__nav-btn round-out-routine__nav-btn--prev" aria-label="Anterior" data-ror-prev>
          <svg width="14" height="9" viewBox="0 0 14 9" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke="currentColor" stroke-width="1.5" d="M1.167 1.5 7 7.333 12.834 1.5"/>
          </svg>
        </button>
        <div class="round-out-routine__dots" data-ror-dots aria-live="polite"></div>
        <button type="button" class="round-out-routine__nav-btn round-out-routine__nav-btn--next" aria-label="Siguiente" data-ror-next>
          <svg width="14" height="9" viewBox="0 0 14 9" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke="currentColor" stroke-width="1.5" d="M1.167 1.5 7 7.333 12.834 1.5"/>
          </svg>
        </button>
      </nav>
    {% endif %}
  </div>
</div>

<script>
  (function() {
    const slider = document.querySelector('[data-round-out-routine]');
    if (!slider) return;
    const track = slider.querySelector('[data-ror-track]');
    const prevBtn = slider.closest('.round-out-routine').querySelector('[data-ror-prev]');
    const nextBtn = slider.closest('.round-out-routine').querySelector('[data-ror-next]');
    const dotsEl = slider.closest('.round-out-routine').querySelector('[data-ror-dots]');
    const cards = slider.querySelectorAll('.round-out-routine__card');
    const total = cards.length;
    const gap = 0;
    let index = 0;

    function setPeekVars() {
      var w = slider.offsetWidth;
      var isMobile = typeof window !== 'undefined' && window.innerWidth <= 749;
      var cardW, peek;
      if (total < 2) {
        cardW = Math.min(w, 520);
        peek = 0;
      } else if (isMobile) {
        cardW = w * 0.8;
        peek = w * 0.1;
      } else {
        cardW = w * 0.58;
        peek = w * 0.21;
      }
      slider.style.setProperty('--ror-card-width', cardW + 'px');
      slider.style.setProperty('--ror-peek-offset', peek + 'px');
    }

    function updateSlider() {
      if (total < 2) {
        if (track) track.style.transform = '';
        return;
      }
      if (!track) return;
      setPeekVars();
      var cardWidthPx = parseFloat(slider.style.getPropertyValue('--ror-card-width')) || (slider.offsetWidth * 0.5);
      var offset = index * (cardWidthPx + gap);
      track.style.transform = 'translate3d(-' + offset + 'px, 0, 0)';
      cards.forEach(function(card, i) {
        card.classList.toggle('round-out-routine__card--active', i === index);
      });
      if (dotsEl) {
        dotsEl.innerHTML = Array.from({ length: total }, function(_, i) {
          return '<span role="button" tabindex="0" data-index="' + i + '" class="round-out-routine__dot' + (i === index ? ' is-active' : '') + '" aria-label="Slide ' + (i + 1) + '"></span>';
        }).join('');
        dotsEl.querySelectorAll('.round-out-routine__dot').forEach(function(dot) {
          dot.addEventListener('click', function() {
            index = parseInt(this.dataset.index, 10);
            updateSlider();
          });
        });
      }
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', function() {
        if (total < 2) return;
        index = index <= 0 ? total - 1 : index - 1;
        updateSlider();
      });
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        if (total < 2) return;
        index = index >= total - 1 ? 0 : index + 1;
        updateSlider();
      });
    }

    setPeekVars();
    updateSlider();
    var resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        setPeekVars();
        updateSlider();
      }, 100);
    });
  })();
</script>

<script>
  (function() {
    const section = document.getElementById('round-out-routine-{{ section.id }}');
    if (!section) return;
    const forms = section.querySelectorAll('form[data-type="add-to-cart-form"]');
    const cartAddUrl = (typeof Theme !== 'undefined' && Theme.routes && Theme.routes.cart_add_url) ? Theme.routes.cart_add_url : '/cart/add.js';

    function getCartSectionIds() {
      const components = document.querySelectorAll('cart-items-component');
      const ids = [];
      components.forEach(function(el) {
        if (el.dataset && el.dataset.sectionId) ids.push(el.dataset.sectionId);
      });
      return ids;
    }

    function openCartDrawer() {
      const drawer = document.querySelector('cart-drawer-component');
      if (drawer && typeof drawer.open === 'function') drawer.open();
    }

    forms.forEach(function(form) {
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        var formEl = e.target;
        var formData = new FormData(formEl);
        var sectionIds = getCartSectionIds();
        if (sectionIds.length) formData.append('sections', sectionIds.join(','));

        var submitBtn = formEl.querySelector('button[type="submit"]');
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.setAttribute('aria-busy', 'true');
        }
        try {
          var res = await fetch(cartAddUrl, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' },
            body: formData
          });
          var data = await res.json();
          if (data.status && data.message) {
            if (typeof window.alert === 'function') window.alert(data.message);
            return;
          }
          document.dispatchEvent(new CustomEvent('cart:update', {
            bubbles: true,
            detail: {
              resource: {},
              sourceId: formEl.id || '',
              data: {
                source: 'round-out-routine',
                itemCount: parseInt(formData.get('quantity') || '1', 10) || 1,
                sections: data.sections || {}
              }
            }
          }));
          openCartDrawer();
        } catch (err) {
          console.error('Add to cart failed:', err);
          if (typeof window.alert === 'function') window.alert('No se pudo agregar al carrito. Intenta de nuevo.');
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.removeAttribute('aria-busy');
          }
        }
      });
    });
  })();
</script>

{% stylesheet %}
  .round-out-routine {
    background-color: var(--ror-bg, #1a1a1a);
    color: var(--ror-text, #fff);
    overflow-x: hidden;
    max-width: 100%;
  }

  .round-out-routine__inner {
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding: 48px 24px 56px;
    overflow-x: hidden;
    box-sizing: border-box;
  }

  .round-out-routine__header {
    margin-bottom: 32px;
    text-align: center;
  }

  .round-out-routine__title {
    margin: 0;
    font-size: 36px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--ror-text);
  }

  .round-out-routine__title-highlight {
    padding: 2px 12px;
    display: inline-block;
  }

  .round-out-routine__slider {
    overflow-x: hidden;
    overflow-y: visible;
    margin: 0 -12px;
    --ror-card-width: 58%;
    --ror-peek-offset: 21%;
  }

  @media (max-width: 749px) {
    .round-out-routine__slider {
      margin: 0;
    }
  }

  .round-out-routine__track {
    display: flex;
    gap: 0;
    padding-left: var(--ror-peek-offset, 25%);
    padding-right: var(--ror-peek-offset, 25%);
    transition: transform 0.35s ease;
    will-change: transform;
    align-items: flex-start;
  }

  .round-out-routine__card {
    flex: 0 0 var(--ror-card-width, 50%);
    width: var(--ror-card-width, 50%);
    min-width: 0;
    max-width: none;
    transition: transform 0.35s ease, opacity 0.35s ease, box-shadow 0.35s ease;
    transform: scale(0.92);
    opacity: 0.78;
    z-index: 0;
  }

  .round-out-routine__card--active {
    transform: scale(1);
    opacity: 1;
    z-index: 2;
    box-shadow: 0 8px 40px rgb(0 0 0 / 0.25);
  }

  @media (max-width: 768px) {
      .round-out-routine__inner {
    padding: 48px 0px 56px;
  }

    .round-out-routine__slider {
      --ror-card-width: 80%;
      --ror-peek-offset: 10%;
      width: 100%;
      min-width: 0;
    }

    .round-out-routine__track {
      min-width: 0;
    }

    .round-out-routine__product-bar--below {
      padding: 10px 12px;
      gap: 10px;
    }

    .round-out-routine__product-bar--below .round-out-routine__product-name {
      font-size: 0.8125rem;
    }

    .round-out-routine__product-bar--below .round-out-routine__btn {
      padding: 6px 12px;
      font-size: 0.75rem;
    }
  }

  .round-out-routine__slider--single .round-out-routine__track {
    padding-left: 0;
    padding-right: 0;
    justify-content: center;
  }

  .round-out-routine__slider--single .round-out-routine__card {
    flex: 0 0 100%;
    width: 100%;
    max-width: 520px;
    transform: scale(1);
    opacity: 1;
    box-shadow: none;
  }

  .round-out-routine__card {
    display: flex;
    flex-direction: column;
    overflow: visible;
    align-items: stretch;
  }

  .round-out-routine__card-media {
    position: relative;
    width: 100%;
    aspect-ratio: var(--ror-aspect-ratio, 1);
    overflow: hidden;
    flex-shrink: 0;
  }

  .round-out-routine__card-media picture,
  .round-out-routine__card-media .round-out-routine__card-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: var(--ror-object-fit, cover);
    object-position: var(--ror-object-position, center);
  }

  .round-out-routine__card-image {
    object-fit: var(--ror-object-fit, cover);
    object-position: var(--ror-object-position, center);
  }

  .round-out-routine__card-media img {
    object-fit: var(--ror-object-fit, cover);
    object-position: var(--ror-object-position, center);
  }

  .round-out-routine__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgb(255 255 255 / 0.06);
  }

  .round-out-routine__placeholder-svg {
    width: 50%;
    opacity: 0.4;
  }

  {% comment %} Desktop: barra overlay sobre la imagen (esquina inferior derecha) {% endcomment %}
  @media (min-width: 750px) {
    .round-out-routine__product-bar--overlay {
      display: flex;
      position: absolute;
      bottom: 16px;
      left: 50%;
      transform: translateX(-50%);
      width: auto;
      max-width: calc(100% - 32px);
      flex-direction: row;
      align-items: center;
      gap: 14px;
      padding: 12px 16px;
      background: #fff;
      color: #1a1a1a;
      box-sizing: border-box;
      box-shadow: 0 4px 20px rgb(0 0 0 / 0.2);
      border-radius: 10px;
      z-index: 1;
    }

    .round-out-routine__product-bar--below {
      display: none;
    }

    .round-out-routine__product-bar--overlay .round-out-routine__product-thumb {
      width: 56px;
      height: 56px;
      flex-shrink: 0;
      border-radius: 8px;
      overflow: hidden;
    }

    .round-out-routine__product-bar--overlay .round-out-routine__product-thumb img,
    .round-out-routine__product-bar--overlay .round-out-routine__product-thumb-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .round-out-routine__product-bar--overlay .round-out-routine__product-info {
      flex: 1 1 auto;
      min-width: 0;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 2px;
    }

    .round-out-routine__product-bar--overlay .round-out-routine__product-name {
      font-weight: 600;
      font-size: 0.95rem;
      line-height: 1.25;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .round-out-routine__product-bar--overlay .round-out-routine__product-subtitle {
      font-size: 0.8rem;
      color: #555;
      line-height: 1.3;
    }

    .round-out-routine__product-bar--overlay form,
    .round-out-routine__product-bar--overlay .round-out-routine__btn {
      flex: 0 0 auto;
    }
  }

  {% comment %} Barra debajo de la foto: solo en móvil; en desktop se oculta {% endcomment %}
  .round-out-routine__product-bar--below {
    display: none;
  }

  @media (max-width: 749px) {
    .round-out-routine__product-bar--overlay {
      display: none;
    }

    .round-out-routine__product-bar--below {
      display: flex;
      width: 100%;
      flex-direction: row;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      background: #fff;
      color: #1a1a1a;
      box-sizing: border-box;
      box-shadow: 0 4px 20px rgb(0 0 0 / 0.2);
    }

    .round-out-routine__product-bar--below .round-out-routine__product-info {
      flex: 1 1 auto;
      min-width: 0;
      display: flex;
      align-items: center;
    }

    .round-out-routine__product-bar--below .round-out-routine__product-name {
      font-weight: 600;
      font-size: 0.9rem;
      word-wrap: break-word;
      overflow-wrap: break-word;
      line-height: 1.3;
    }

    .round-out-routine__product-bar--below form,
    .round-out-routine__product-bar--below .round-out-routine__btn {
      flex: 0 0 auto;
    }
  }

  .round-out-routine__btn {
    background: var(--ror-accent, #ffba25);
    color: var(--ror-accent-text, #011732);
    border: none;
    padding: 10px 20px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .round-out-routine__btn:hover:not(:disabled) {
    opacity: 0.9;
  }

  .round-out-routine__btn--disabled,
  .round-out-routine__btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .round-out-routine__card-content {
    width: 100%;
    box-sizing: border-box;
    padding: 20px 16px 28px;
    background: var(--ror-card-bg, #1a1a1a);
    text-align: center;
    flex: 0 0 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .round-out-routine__headline {
    margin: 0 0 8px;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--ror-headline-color, var(--ror-text));
    text-align: center;
    width: 100%;
    box-sizing: border-box;
  }

  .round-out-routine__description {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--ror-description-color, var(--ror-text));
    opacity: 0.95;
    text-align: center;
    width: 100%;
    box-sizing: border-box;
  }

  .round-out-routine__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 24px;
  }

  .round-out-routine__nav-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--ror-accent);
    background: var(--ror-accent);
    color: var(--ror-accent-text);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
  }

  .round-out-routine__nav-btn:hover {
    opacity: 0.9;
  }

  .round-out-routine__nav-btn svg {
    width: 14px;
    height: 9px;
  }

  .round-out-routine__nav-btn--prev svg {
    transform: rotate(90deg);
  }

  .round-out-routine__nav-btn--next svg {
    transform: rotate(-90deg);
  }

  .round-out-routine__dots {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .round-out-routine__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgb(255 255 255 / 0.4);
    cursor: pointer;
    transition: background 0.2s;
  }

  .round-out-routine__dot.is-active {
    background: var(--ror-accent);
  }

  .round-out-routine__dot:hover {
    background: rgb(255 255 255 / 0.7);
  }

  .round-out-routine__product-price{
  font-size: 0.85rem;
  font-weight: 600;
  color: #666;
  line-height: 1.2;
}
{% endstylesheet %}

